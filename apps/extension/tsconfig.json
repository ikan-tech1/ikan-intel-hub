{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "types": ["chrome", "node"],
    "noEmit": true,
    "verbatimModuleSyntax": false
  },
  "include": ["entrypoints/**/*", "src/**/*", "wxt.config.ts"]
}
