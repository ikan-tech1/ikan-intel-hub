# ============================================
# CORE SECRETS
# ============================================

# NIM API (https://integrate.api.nvidia.com/)
NVIDIA_NIM_API_KEY=nvapi-...

# AI Fallbacks
OPENROUTER_API_KEY=sk-or-...  # Optional fallback
GROQ_API_KEY=gsk_...           # Optional fallback

# Search APIs (LinkedIn integration)
SERPAPI_KEY=...                 # Free tier: 100/mo; ~$50/mo for paid
BING_SEARCH_KEY=...             # Free tier: 1000/mo on Azure

# Email
RESEND_API_KEY=re_...           # For magic links + transactional email

# Auth
AUTH_SECRET=...                 # 32+ random chars; `openssl rand -hex 32`
AUTH_URL=http://localhost:3000  # Override in prod to https://hub.ikan.example

# Database
DATABASE_URL=postgresql://...   # Neon: postgresql://user:pass@host/db
DIRECT_URL=${DATABASE_URL}      # For migrations; same or IP-allowlisted proxy

# Redis (Upstash)
UPSTASH_REDIS_URL=redis://...
UPSTASH_REDIS_TOKEN=...

# Storage (Cloudflare R2)
R2_ACCOUNT_ID=...
R2_ACCESS_KEY=...
R2_SECRET_KEY=...
R2_BUCKET_NAME=ikan-hub

# ============================================
# APP CONFIGURATION
# ============================================

# LLM Provider fallback order
AI_PROVIDER_ORDER=nim,openrouter,groq

# Daily token budget (prevents runaway costs)
AI_DAILY_TOKEN_CAP=1000000

# Contact discovery rate limit (per user, per day)
CONTACTS_DISCOVERY_RATE_LIMIT_DAILY=200

# ============================================
# WORKERS (Fly.io)
# ============================================

BULLMQ_QUEUE_DB=1                 # Redis DB for BullMQ
BULLMQ_QUEUE_NAME=scrape          # Primary queue name

# Scraper timeouts
SCRAPE_TIMEOUT_MS=15000
SCRAPE_BATCH_SIZE=5

# ============================================
# ADMIN / OBSERVABILITY
# ============================================

# Sentry (error tracking)
SENTRY_DSN=...                    # Optional
SENTRY_ORG=...
SENTRY_PROJECT=...

# Axiom (logging)
AXIOM_API_TOKEN=...               # Optional

# PostHog (product analytics)
NEXT_PUBLIC_POSTHOG_KEY=...       # Optional; prefixed with NEXT_PUBLIC_ for client

# ============================================
# ENCRYPTION
# ============================================

# Contact point encryption (AES-256-GCM)
CONTACT_ENC_KEY=...               # 32 random bytes, base64-encoded

# Extension shared secret (validates ingest tokens)
EXTENSION_SHARED_SECRET=...        # 32+ random chars

# ============================================
# DEV-ONLY OVERRIDES
# ============================================

# Use in development to skip email verification
SKIP_EMAIL_VERIFICATION=false

# Force provider (dev testing)
FORCE_AI_PROVIDER=                 # Options: nim, openrouter, groq; empty = auto

# Mock external APIs (dev mode)
MOCK_EXTERNAL_APIS=false

# ============================================
# NEXT.js
# ============================================

NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Turbo caching (monorepo builds)
TURBO_CACHE_WRITE_TOKEN=...        # Optional; from Vercel
