{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": [".env", ".env.local"],
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "DIRECT_URL",
    "REDIS_URL",
    "NVIDIA_NIM_API_KEY",
    "NVIDIA_NIM_BASE_URL",
    "OPENROUTER_API_KEY",
    "GROQ_API_KEY",
    "AI_PROVIDER_ORDER",
    "AI_DAILY_TOKEN_CAP",
    "SERPAPI_KEY",
    "BING_SEARCH_KEY",
    "AUTH_SECRET",
    "AUTH_URL",
    "RESEND_API_KEY",
    "RESEND_FROM",
    "EXTENSION_SHARED_SECRET",
    "R2_ACCOUNT_ID",
    "R2_ACCESS_KEY_ID",
    "R2_SECRET_ACCESS_KEY",
    "R2_BUCKET",
    "NEXT_PUBLIC_APP_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "clean": {
      "cache": false
    }
  }
}
